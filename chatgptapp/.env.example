PORT=9393
HOST=0.0.0.0

# Existing SnapScan REST API base URL
SNAPSCAN_API_BASE=http://localhost:8787

# Shared key used by the ChatGPT app MCP server when no client key is provided
# Keep this as demo_* for local mode, or set to a real key you provision in production
SNAPSCAN_API_KEY=demo_chatgpt_app

# Global safety limit for this MCP server instance
MCP_RATE_LIMIT_PER_MINUTE=60

# Timeout for upstream API requests
UPSTREAM_TIMEOUT_MS=10000

# App metadata shown to compatible clients
WEBSITE_URL=https://snapscan.app
