# Copy to .env and fill in real values
PORT=8787
NODE_ENV=development

# Public base URLs
API_BASE_URL=http://localhost:8787
WEB_BASE_URL=http://localhost:5173

# Supabase — create a project at supabase.com, then get these from Project Settings > API
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Stripe — from dashboard.stripe.com (use test keys for dev)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs for each tier (create in Stripe dashboard as recurring monthly prices)
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...
